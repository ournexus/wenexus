{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@wenexus/ui": ["../../packages/ui/src"],
      "@wenexus/types": ["../../packages/types/src"],
      "@wenexus/utils": ["../../packages/utils/src"],
      "@wenexus/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
