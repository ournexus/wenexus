{
  "name": "@wenexus/frontend",
  "version": "1.0.0",
  "description": "WeNexus Frontend Monorepo - Web, Admin, and Mobile applications",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@turbo/gen": "^1.10.12",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.8.10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.1"
    }
  }
}
