{
  "name": "wenexus",
  "version": "1.0.0",
  "description": "The Consensus Amplifier - A platform for meaningful connections and understanding",
  "private": true,
  "scripts": {
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:lint": "pnpm --dir frontend lint",
    "frontend:test": "pnpm --dir frontend test",
    "frontend:test:e2e": "pnpm --dir frontend/apps/web test:e2e",
    "frontend:test:e2e:smoke": "pnpm --dir frontend/apps/web test:e2e:smoke",
    "backend:java:build": "mvn -f backend/java/pom.xml clean package",
    "backend:java:test": "mvn -f backend/java/pom.xml test",
    "backend:python:dev": "cd backend/python && uv run uvicorn src.main:app --reload",
    "backend:python:test": "cd backend/python && uv run pytest",
    "prepare": "husky install",
    "precommit": "pre-commit run --all-files",
    "setup": "./tools/scripts/setup-dev.sh",
    "setup:precommit": "./tools/scripts/setup-precommit.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "husky": "^8.0.3",
    "pre-commit": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
